<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="delivery_method_list" model="ir.ui.view">
        <field name="name">delivery.method.list</field>
        <field name="model">delivery.method</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
     </record>

    <record id="delivery_method_form" model="ir.ui.view">
        <field name="name">delivery.method.form</field>
        <field name="model">delivery.method</field>
        <field name="arch" type="xml">
            <form>
                <shee>
                    <group>
                        <field name="name"/>
                        <field name="inter_region_available"/>
                    </group>
                </shee>
            </form>
        </field>
    </record>

    <record id="action_delivery_method" model="ir.actions.act_window">
        <field name="name">Delivery mode</field>
        <field name="res_model">delivery.method</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>