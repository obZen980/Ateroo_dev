<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="delivery_category_list" model="ir.ui.view">
        <field name="name">delivery.category.list</field>
        <field name="model">delivery.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="weight_limit" string="Weight limit (kq)"></field>
                <field name="description"/>
            </list>
        </field>
     </record>

    <record id="delivery_category_form" model="ir.ui.view">
        <field name="name">delivery.category.form</field>
        <field name="model">delivery.category</field>
        <field name="arch" type="xml">
            <form>
                <shee>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="weight_limit" string="Weight limit (kq)"/>
                        <field name="coef_price"/>
                    </group>
                </shee>
            </form>
        </field>
    </record>

    <record id="action_delivery_category" model="ir.actions.act_window">
        <field name="name">Delivery category</field>
        <field name="res_model">delivery.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>