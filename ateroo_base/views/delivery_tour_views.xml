<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="delivery_tour_form" model="ir.ui.view">
        <field name="name">delivery.tour.form</field>
        <field name="model">delivery.tour</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" force_save="True"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="driver_id"/>
                            <field name="start_date"/>
                        </group>
                    </group>
                    <notebook>
                        <field name="package_domain" invisible="1"/>
                        <page string="Packages" invisible="not type" >
                            <field name="package_ids" domain="package_domain" widget="ateroo_tour_list_one2many" style="width:100%">
                                <list>
                                    <field name="id" column_invisible="1"/> <!-- important -->
                                    <field name="sequence" style="width:100%"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="delivery_tour_list" model="ir.ui.view">
        <field name="name">delivery.tour.list</field>
        <field name="model">delivery.tour</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="driver_id"/>
                <field name="start_date"/>
                <field name="state"/>
            </list>
        </field>
     </record>
    <record id="action_delivery_tour" model="ir.actions.act_window">
        <field name="name">Delivery tour</field>
        <field name="res_model">delivery.tour</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>