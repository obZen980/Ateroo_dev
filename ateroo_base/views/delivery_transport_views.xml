<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="delivery_transport_list" model="ir.ui.view">
        <field name="name">delivery.transport.list</field>
        <field name="model">delivery.transport</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
     </record>

    <record id="delivery_transport_form" model="ir.ui.view">
        <field name="name">delivery.transport.form</field>
        <field name="model">delivery.transport</field>
        <field name="arch" type="xml">
            <form>
                <shee>
                    <group>
                        <field name="name"/>
                        <field name="coef_price"/>
                    </group>
                </shee>
            </form>
        </field>
    </record>

    <record id="action_delivery_transport" model="ir.actions.act_window">
        <field name="name">Delivery transport</field>
        <field name="res_model">delivery.transport</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>