<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="delivery_package_form" model="ir.ui.view">
        <field name="name">delivery.package.form</field>
        <field name="model">delivery.package</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight" invisible="state not in ['draft'] or to_retrieve"/>
                    <button name="action_generate_routes" type="object" string="Generate routes" class="oe_highlight" invisible="state not in ['draft'] or delivery_picking_ids"/>

                    <button name="action_in_sort" type="object" string="In Sort" class="oe_highlight" invisible="state != 'reception'"/>
                    <button name="action_ready" type="object" string="Delivery ready" class="oe_highlight" invisible="state != 'in_sort'"/>
                    <button name="action_planned" type="object" string="Delivery planned" class="oe_highlight" invisible="state != 'ready'"/>
<!--                    <button name="action_delivery_in_progress" type="object" string="Delivery in progress" class="oe_highlight" invisible="state not in ('ready', 'planned')"/>-->
<!--                    <button name="action_delivered" type="object" string="Delivery done" class="oe_highlight" invisible="state not in ('delivery_in_progress', 'delivery_deposit')"/>-->
<!--                    <button name="action_delivery_in_deposit" type="object" string="Delivery in deposit" invisible="state not in ('delivery_in_progress')"/>-->
                    <button name="action_create_invoice" class="oe_highlight"  type="object" string="Create invoice" invisible="state not in ('reception', 'delivered') or invoice_count"/>
                    <field name="state" widget="statusbar" statusbar_visible="reception,in_sort,ready,planned,delivery_in_progress,delivered,paid"/>
                </header>
                <sheet style="overflow: hidden;">
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>
                    <div class="oe_title" invisible="not sequence">
                        <h1>
                            <field name="sequence" readonly="1"/>
                        </h1>
                    </div>
                    <div class="oe_title" invisible="sequence">
                        <h1>
                            <span>New</span>
                        </h1>
                    </div>
                    <div class="oe_title">
                        <h2>
                            <label for="name"/>
                            <field name="name"/>
                        </h2>
                    </div>
                    <group name="options" string="Parameter">
                        <group>
                            <field name="delivery_method_id"/>
                            <field name="network" widget="radio" options="{'horizontal': True}" readonly="not inter_region_available" force_save="True"/>
                            <field name="to_retrieve"/>
                            <field name="cash_on_delivery"/>
                            <field name="date"/>
                            <field name="date_planned"/>
                        </group>
                        <group>

                        </group>

                    </group>
                    <group name="package_sender" string="Sender" col="12">
                        <group colspan="4">
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="city"/>
                        </group>
                        <group colspan="4">
                            <field name="street" widget="osm_address_autocomplete"/>
                            <field name="street2"/>
                            <field name="landmark"/>
                            <field name="region_id"/>
                        </group>
                        <group colspan="4">
                            <field name="agency_id" invisible="not inter_region_available"/>
                        </group>
                        <label for="sender_note"/>
                        <field name="sender_note"/>
                    </group>
                    <group name="package_recipient" string="Recipient" col="12">
                        <group colspan="4">
                            <field name="recipient_name"/>
                            <field name="recipient_phone"/>
                            <field name="recipient_email"/>
                            <field name="recipient_city"/>
                        </group>
                        <group colspan="4">
                            <field name="recipient_street" widget="osm_address_autocomplete" />
                            <field name="recipient_street2"/>
                            <field name="recipient_landmark"/>
                            <field name="recipient_region_id"/>
                        </group>
                        <group colspan="4">
                            <field name="dest_agency_id" invisible="not inter_region_available or network == 'intra_urban'"/>
                        </group>
                        <label for="recipient_note"/>
                        <field name="recipient_note"/>
                    </group>
                    <group name="package_infos">
                        <group name="details" string="Pacakge details">
                            <div class="d-flex align-items-baseline">
                                <span style="min-width: 100px;">
                                    <label for="category_id" style="min-width: 100px;"/>
                                </span>
                                 <field name="category_id" style="min-width:160px" options="{'no_create_edit': True, 'no_quick_create': True, 'no_create': True}" />
                            </div>
                            <br/>
                            <div class="d-flex align-items-baseline">
                                <span style="min-width: 100px;">
                                    <label for="weight" style="min-width: 100px;"/>
                                </span>
                                <field name="weight" style="min-width:60px"/>
                                <span>Kg</span>
                            </div>
                            <br/>
                            <div class="d-flex align-items-baseline">
                                <span style="min-width: 100px;">
                                    <label for="height" style="min-width: 100px;"/>
                                </span>
                                <field name="height" style="min-width:60px"/>
                                <span>Cm</span>
                            </div>
                            <br/>
                            <div class="d-flex align-items-baseline">
                                <span style="min-width: 100px;">
                                    <label for="width"/>
                                </span>
                                <field name="width" style="min-width:60px"/>
                                <span>Cm</span>
                            </div>
                            <br/>
                            <div class="d-flex align-items-baseline">
                                <span style="min-width: 100px;">
                                    <label for="length"/>
                                </span>
                                <field name="length" style="min-width:60px"/>
                                <span>Cm</span>
                            </div>
                            <br/>
                            <div class="d-flex align-items-baseline">
                                <span style="min-width: 100px;">
                                    <label for="volume" style="min-width: 100px;"/>
                                </span>
                                <field name="volume" style="width:60px"/>
                                <span>Cm3</span>
                            </div>
                        </group>
                        <group name="pricing" string="Pricing">
                            <field name="product_tmpl_id"/>
                            <field name="customer_type" invisible="1"/>
                            <field name="include_package_price" invisible="customer_type not in ('e_commerce')"/>
                            <field name="package_price" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" invisible="not include_package_price" />
                            <field name="pricelist_id"/>
                            <field name="currency_id" invisible="1"/>
                            <separator/>
                            <div class="o_row">
                                <label for="amount_total"/>
                                <h2><field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}"/></h2>
                            </div>

                        </group>
                    </group>

                    <notebook>
                        <page string="Operations">
                            <group>
                                <field name="current_location_id"/>
                            </group>
                            <field name="delivery_picking_ids" readonly="state != 'draft'" context="{'default_type': 'delivery'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="type"/>
                                    <field name="departure_id" context="{'active_test': False}"/>
                                    <field name="destination_id" context="{'active_test': False}"/>
                                    <field name="state" readonly="1"/>
                                    <field name="start_date" readonly="1"/>
                                    <field name="end_date" readonly="1"/>
                                    <field name="display_duration"/>
<!--                                    <button name="action_start" type="object" string="Start" class="oe_highlight" invisible="state != 'none' or not (departure_id and destination_id)"/>-->
<!--                                    <button name="action_done" type="object" string="End" class="oe_highlight" invisible="state != 'in_progress'"/>-->
                                </list>
                            </field>
                            <separator/>
                            <field name="internal_picking_ids" readonly="state not in ('in_sort', 'ready', 'planned')" invisible="state not in ('in_sort', 'ready', 'planned')" context="{'default_type': 'internal'}">
                                <list editable="bottom">
                                    <field name="internal_domain" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="type"/>
                                    <field name="departure_id" context="{'active_test': False}" domain="internal_domain"/>
                                    <field name="destination_id" context="{'active_test': False}" domain="internal_domain"/>
                                    <field name="state" readonly="1"/>
                                    <field name="start_date" readonly="1"/>
                                    <field name="end_date" readonly="1"/>
                                    <field name="display_duration"/>
<!--                                    <button name="action_start" type="object" string="Start" class="oe_highlight" invisible="state != 'none' or not (departure_id and destination_id)"/>-->
<!--                                    <button name="action_done" type="object" string="End" class="oe_highlight" invisible="state != 'in_progress'"/>-->
                                </list>
                            </field>

                        </page>
                        <page string="Tracking" >
                            <group>
                                <field name="map_latitude" invisible="0"/>
                                <field name="map_longitude" invisible="0"/>
                                <div class="o_row">
                                    <field name="map" invisible="1"/>
                                    <field name="map" widget="tracking_map" options="{'type': 'latitude'}"/>
                                </div>
                            </group>
                        </page>
                        <page string="Photos">
                            <group>
                                <div class="o_row">
                                    <field name="image_1920" invisible="1"/>
                                    <field name="image_2" invisible="1"/>
                                    <field name="image_3" invisible="1"/>
                                    <field name="image_selector" widget="image_selector" no_label="1"/>
                                </div>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="delivery_package_tree" model="ir.ui.view">
        <field name="name">delivery.package.tree</field>
        <field name="model">delivery.package</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="agency_id"/>
                <field name="category_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
     </record>

    <record id="delivery_package_search" model="ir.ui.view">
        <field name="name">delivery.package.search</field>
        <field name="model">delivery.package</field>
        <field name="arch" type="xml">
            <search string="Search delivery pacakge">
                <field name="name" string="Delivery package"
                    filter_domain="['|', '|', ('name', 'ilike', self), ('sequence', 'ilike', self), ('partner_id', 'child_of', self)]"/>
                <field name="partner_id" operator="child_of"/>
                <field name="agency_id" string="Agency"/>
                <field name="state"/>
                <field name="date"/>

                <filter string="New package" domain="[('state', 'in', ['draft', 'reception'])]" name="new_package"/>
                <filter string="In delivery" domain="[('state', 'in', ['ready', 'planned'])]" name="ready_delivery"/>
                <filter string="In sorting" domain="[('state', 'in', ['in_sort'])]" name="in_sort"/>
                <group expand="0" string="Group By">
                    <filter string="state" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter name="customer" string="Customer" domain="[]" context="{'group_by': 'partner_id'}"/>
                    <filter string="Delivery Date" name="delivery" domain="[]" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_delivery_package" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">delivery.package</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>