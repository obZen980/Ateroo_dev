<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_city_form_view" model="ir.ui.view">
        <field name="name">res.city.form.view</field>
        <field name="model">res.city</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <record id="res_city_tree_view" model="ir.ui.view">
        <field name="name">res.city.tree.view</field>
        <field name="model">res.city</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
     </record>
    <record id="action_res_city" model="ir.actions.act_window">
        <field name="name">Ville</field>
        <field name="res_model">res.city</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>