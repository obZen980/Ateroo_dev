<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="wizard_map_form" model="ir.ui.view">
        <field name="name">wizard.map.form</field>
        <field name="model">wizard.map</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="o_row">
                        <field name="address" invisible="1"/>
                        <field name="pick_id" invisible="1"/>
                        <field name="departure_latitude" invisible="1"/>
                        <field name="departure_longitude" invisible="1"/>
                        <field name="destination_latitude" invisible="1"/>
                        <field name="destination_longitude" invisible="1"/>
                        <field name="address" widget="tracking_map" options="{'type': 'address'}" invisible="not address"/>
                        <field name="address" widget="tracking_map" options="{'type': 'route'}" invisible="not pick_id"/>
                    </div>
                </sheet>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>